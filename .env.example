# ===========================================
# APPLYR ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values
# You can get Firebase credentials from: https://console.firebase.google.com/project/applyr-production/settings/general

# ----- FIREBASE CLIENT SDK (Public - Safe for browser) -----
# Get these from Firebase Console > Project Settings > General > Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=applyr-production.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=applyr-production
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=applyr-production.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ----- YOUR APP URL (For OAuth callbacks) -----
# Update this to your Vercel deployment URL after deploying
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# ----- FIREBASE ADMIN SDK (Private - Server-side only!) -----
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_ADMIN_PROJECT_ID=applyr-production
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@applyr-production.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ----- GOOGLE OAUTH (For Drive & Gmail API access) -----
# Create credentials at: https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# This should match your app URL + /api/auth/google/callback
GOOGLE_REDIRECT_URI=https://your-app-name.vercel.app/api/auth/google/callback

# ----- TELEGRAM BOT -----
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# A secret string you make up (used to verify webhook requests are genuine)
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# ----- GMAIL PUB/SUB (For real-time email notifications) -----
# Create a Pub/Sub topic in Google Cloud Console
# Grant publish permission to: gmail-api-push@system.gserviceaccount.com
GMAIL_PUBSUB_TOPIC=projects/applyr-production/topics/gmail-notifications

# ----- GEMINI AI (For AI features) -----
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ----- ENCRYPTION KEY (For secure token storage) -----
# Generate a random 32+ character string
ENCRYPTION_SECRET_KEY=your_random_encryption_key_min_32_chars
