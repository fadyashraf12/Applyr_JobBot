# ===========================================
# APPLYR ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values

# ----- FIREBASE CLIENT SDK (From Firebase Console > Project Settings > General) -----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=applyr-production.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=applyr-production
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=applyr-production.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ----- YOUR APP URL -----
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# ----- FIREBASE ADMIN SDK (From your downloaded JSON key file) -----
FIREBASE_ADMIN_PROJECT_ID=applyr-production
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@applyr-production.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ----- GOOGLE OAUTH (Create at console.cloud.google.com/apis/credentials) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app-name.vercel.app/api/auth/google/callback

# ----- TELEGRAM BOT (From @BotFather) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ----- GMAIL PUB/SUB -----
GMAIL_PUBSUB_TOPIC=projects/applyr-production/topics/gmail-notifications

# ----- GEMINI AI (From aistudio.google.com/apikey) -----
GEMINI_API_KEY=

# ----- ENCRYPTION KEY (32+ random characters) -----
ENCRYPTION_SECRET_KEY=
