rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Seekers Users Configuration (Completely isolated by owner UID)
    match /users/{userId} {
      allow read, write: if isOwner(userId) && isValidId(userId);

      // Recursive nested access control for sub-collections
      match /config/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /profiles/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /applications/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /drafts/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /botSession/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 3. Telegram mappings: Strictly server-side write & read. No Client accesses.
    match /telegram_mappings/{mappingId} {
      allow read, write: if false;
    }

    // 4. Session tokens: Strictly server-side write & read. No Client accesses.
    match /pairing_tokens/{token} {
      allow read, write: if false;
    }
  }
}
